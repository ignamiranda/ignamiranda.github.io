---
import Layout from "../../layouts/Layout.astro";
import { getAllTags } from "../../lib/backlinks";
const tags = getAllTags();
---

<Layout title="Tags">
  <main>
    <section class="section">
      <h2 class="section-heading">Tags</h2>
      {tags.length > 0 ? (
        <div class="tag-list">
          {tags.map((t) => (
            <a href={`/tags/${t.tag.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]+/g, '')}`} class="tag-item">
              <span class="tag-name">{t.tag}</span>
              <sup class="tag-count">{t.count}</sup>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-text">No tags yet.</p>
      )}
    </section>
  </main>
</Layout>

<style>
  .tag-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tag-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    padding: 0.5rem 0;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    font-size: 1.05rem;
    width: fit-content;
    border-bottom: 1px solid color-mix(in srgb, var(--fg) 4%, transparent);
  }
  .tag-item:last-child {
    border-bottom: none;
  }
  .tag-item:hover {
    color: var(--accent);
    opacity: 1;
  }

  .tag-name {
    font-family: var(--font-mono);
  }

  .tag-count {
    font-size: 0.75rem;
    color: var(--muted-dim);
  }

  .empty-text {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>
