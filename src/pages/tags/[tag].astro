---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { previewText as _previewText } from "../../lib/markdown";
import { tagSlug } from "../../lib/slugify";

export async function getStaticPaths() {
  const notes = (await getCollection("notes")).filter((n) => !n.data.draft);
  const tags = new Set<string>();
  for (const note of notes) {
    for (const tag of (note.data.tags || [])) {
      tags.add(tag);
    }
  }
  return [...tags].map(tag => ({
    params: { tag: tagSlug(tag) },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const notes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .filter(n => (n.data.tags || []).includes(tag))
  .sort((a, b) => (b.data.date || "").localeCompare(a.data.date || ""));

function previewText(body: string): string {
  return _previewText(body, 200);
}
---

<Layout title={`#${tag}`} description={`Notes tagged "${tag}" on ignamiranda's digital garden.`}>
  <main>
    <section class="section">
      <h2 class="section-heading"># {tag}</h2>
      {notes.length > 0 ? (
        <div class="card-grid">
          {notes.map((note) => {
            const preview =
              note.data.description ||
              (note.body ? previewText(note.body) : "");
            return (
              <a href={`/notes/${note.slug}`} class="card">
                <h3 class="card-title">{note.data.title || note.slug}</h3>
                {note.data.date && (
                  <p class="card-date">{note.data.date}</p>
                )}
                {preview && <p class="card-desc">{preview}</p>}
              </a>
            );
          })}
        </div>
      ) : (
        <p class="empty-text">No notes with this tag.</p>
      )}
    </section>
  </main>
</Layout>

<style>
  .card-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }

  .empty-text {
    color: var(--muted);
    font-size: 0.95rem;
  }
</style>
