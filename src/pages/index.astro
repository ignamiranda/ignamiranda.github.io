---
import Layout from "../layouts/Layout.astro";
import ForceGraph from "../components/ForceGraph.astro";
import { getCollection } from "astro:content";
const notes = await getCollection("notes");

function stripMarkdown(body: string): string {
  return body
    .replace(/^#+\s+/gm, "")
    .replace(/[*_~`]/g, "")
    .replace(/\[([^\]]*)\]\([^)]*\)/g, "$1")
    .replace(/!\[([^\]]*)\]\([^)]*\)/g, "$1")
    .replace(/>\s*/g, "")
    .replace(/---+/g, "")
    .replace(/\n+/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function previewText(body: string): string {
  const stripped = stripMarkdown(body);
  if (stripped.length <= 150) return stripped;
  return stripped.substring(0, 150).replace(/\s+\S*$/, "") + "\u2026";
}
---

<Layout title="ignamiranda">
  <main>
    <section class="hero">
      <h1>
        <span class="name">ignamiranda</span>
        <span class="tagline">builds things</span>
      </h1>
      <p class="blurb">
        A playground for software, design, and games.
      </p>
      <nav class="links">
        <a href="https://github.com/ignamiranda" target="_blank">GitHub</a>
        <a href="mailto:ignamiranda@users.noreply.github.com">Email</a>
      </nav>
    </section>

    <section class="section" id="graph">
      <h2 class="section-title">Graph</h2>
      <ForceGraph />
    </section>

    <section class="section" id="generators">
      <h2 class="section-title">Generators</h2>
      <div class="card-grid">
        <a href="/name-generator" class="card">
          <h3 class="card-title">Name Generator</h3>
          <p class="card-desc">
            Build your own Markov-chain name generator — fantasy, sci-fi, or anything you dream up.
          </p>
          <span class="card-meta">Create your own &rarr;</span>
        </a>
      </div>
    </section>

    <section class="section" id="notes">
      <h2 class="section-title">Notes</h2>
      {notes.length > 0 ? (
        <>
          <a href="#" class="random-note" id="random-note-btn">Random note</a>
          <div class="card-grid">
            {notes.map((note) => {
              const preview =
                note.data.description ||
                (note.body ? previewText(note.body) : "");
              return (
                <a href={`/notes/${note.slug}`} class="card">
                  <h3 class="card-title">{note.data.title || note.slug}</h3>
                  {preview && <p class="card-desc">{preview}</p>}
                </a>
              );
            })}
          </div>
        </>
      ) : (
        <p class="note-empty">Nothing here yet.</p>
      )}
    </section>

    <script type="application/json" id="index-notes-data">
      {JSON.stringify(notes.map((n) => ({ slug: n.slug, title: n.data.title })))}
    </script>

    <script>
      (function () {
        const btn = document.getElementById("random-note-btn");
        const dataEl = document.getElementById("index-notes-data");
        if (!btn || !dataEl) return;
        const notes = JSON.parse(dataEl.textContent || "[]");
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          if (!notes.length) return;
          var pick = notes[Math.floor(Math.random() * notes.length)];
          window.location.href = "/notes/" + encodeURIComponent(pick.slug);
        });
      })();
    </script>
  </main>
</Layout>

<style>
    .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
  }

  h1 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .name {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tagline {
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .blurb {
    font-size: 1.1rem;
    max-width: 32rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--fg);
    border: 1px solid var(--muted);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    transition: all 0.2s;
  }

  .links a:hover {
    border-color: var(--accent);
    color: var(--accent);
    opacity: 1;
  }

  /* ─── Sections ─── */
  .section {
    max-width: 52rem;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .card-grid {
    display: grid;
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1.5rem;
    border: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    border-radius: 12px;
    transition: all 0.25s;
    color: var(--fg);
    text-decoration: none;
  }
  .card:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 4%, transparent);
    opacity: 1;
    transform: translateY(-2px);
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    background: linear-gradient(135deg, var(--accent), var(--accent3));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  /* ─── Notes ─── */
  .random-note {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .random-note:hover {
    color: var(--accent);
    opacity: 1;
  }

  .note-empty {
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* ─── Graph ─── */
  #graph {
    padding: 0 2rem 4rem;
  }
</style>
