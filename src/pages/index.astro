---
import Layout from "../layouts/Layout.astro";
import ForceGraph from "../components/ForceGraph.astro";
import { getCollection } from "astro:content";
import { getAllTags } from "../lib/backlinks";
import { tagSlug } from "../lib/slugify";
import { previewText as _previewText } from "../lib/markdown";
const notes = (await getCollection("notes")).filter((n) => !n.data.draft);
const allTags = getAllTags();

function previewText(body: string): string {
  return _previewText(body, 150);
}
---

<Layout title="ignamiranda" description="A playground for software, design, and games. Notes, tools, and experiments by ignamiranda.">
  <main id="main-content">
    <!-- ─── Hero ─── -->
    <section class="hero">
      <h1 class="hero-name">ignamiranda</h1>
      <div class="hero-accent" aria-hidden="true"></div>
      <p class="hero-tagline">builds things</p>
      <p class="hero-blurb">A playground for software, design, and games.</p>
      <nav class="hero-links">
        <a href="https://github.com/ignamiranda" target="_blank" rel="noopener">GitHub</a>
        <a href="mailto:ignamiranda@users.noreply.github.com">Email</a>
      </nav>
    </section>

    <!-- ─── Graph ─── -->
    <section class="section" id="graph">
      <h2 class="section-heading">Graph</h2>
      <ForceGraph />
    </section>

    <!-- ─── Generators ─── -->
    <section class="section" id="generators">
      <h2 class="section-heading">Generators</h2>
      <div class="card-grid">
        <a href="/notes/name-generator" class="card">
          <h3 class="card-title">Name Generator</h3>
          <p class="card-desc">
            Build your own Markov-chain name generator — fantasy, sci-fi, or anything you dream up.
          </p>
          <span class="card-meta">Create your own &rarr;</span>
        </a>
        <a href="/notes/rumors-generator" class="card">
          <h3 class="card-title">Rumors Generator</h3>
          <p class="card-desc">
            A slot machine for fantasy tavern rumors. Press the button, get a hook.
          </p>
          <span class="card-meta">Generate a rumor &rarr;</span>
        </a>
      </div>
    </section>

    <!-- ─── Notes ─── -->
    <section class="section" id="notes">
      <h2 class="section-heading">Notes</h2>
      {notes.length > 0 ? (
        <>
          <a href="#" class="random-note" id="random-note-btn">Random note</a>
          <div class="card-grid">
            {notes.map((note) => {
              const preview =
                note.data.description ||
                (note.body ? previewText(note.body) : "");
              return (
                <a href={`/notes/${note.slug}`} class="card">
                  <h3 class="card-title">{note.data.title || note.slug}</h3>
                  {preview && <p class="card-desc">{preview}</p>}
                </a>
              );
            })}
          </div>
        </>
      ) : (
        <p class="empty-text">Nothing here yet.</p>
      )}
    </section>

    <!-- ─── Tags ─── -->
    {allTags.length > 0 && (
    <section class="section" id="tags">
      <h2 class="section-heading">Tags</h2>
      <div class="tag-cloud">
        {allTags.map(t => (
          <a href={`/tags/${tagSlug(t.tag)}`} class="tag-item">{t.tag}<sup aria-hidden="true">{t.count}</sup><span class="sr-only">{t.count} notes</span></a>
        ))}
      </div>
    </section>
    )}

    <script type="application/json" id="index-notes-data">
      {JSON.stringify(notes.map((n) => n.slug))}
    </script>

    <script>
      (function () {
        const btn = document.getElementById("random-note-btn");
        const dataEl = document.getElementById("index-notes-data");
        if (!btn || !dataEl) return;
        let slugs;
        try {
          slugs = JSON.parse(dataEl.textContent || "[]");
        } catch {
          return;
        }
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          if (!slugs.length) return;
          var pick = slugs[Math.floor(Math.random() * slugs.length)];
          window.location.href = "/notes/" + encodeURIComponent(pick);
        });
      })();
    </script>
  </main>
</Layout>

<style>
  /* ─── Hero ─── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--fg);
  }

  .hero-accent {
    width: 3rem;
    height: 3px;
    background: var(--accent);
    margin: 1.25rem auto;
    border-radius: 2px;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--muted);
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  .hero-blurb {
    font-size: 1.05rem;
    max-width: 28rem;
    color: var(--muted);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-links {
    display: flex;
    gap: 1.5rem;
  }

  .hero-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
    opacity: 1;
  }

  /* ─── Notes ─── */
  .random-note {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--fg) 8%, transparent);
    border-radius: var(--radius-sm);
    transition: border-color 0.2s, color 0.2s;
  }
  .random-note:hover {
    color: var(--accent);
    border-color: var(--accent);
    opacity: 1;
  }

  .empty-text {
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* ─── Graph ─── */
  #graph {
    max-width: none;
    padding: 0 2rem 5rem;
  }

  #graph .section-heading {
    max-width: 52rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* ─── Tag cloud ─── */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }

  .tag-item {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .tag-item:hover {
    color: var(--accent);
    opacity: 1;
  }
  .tag-item sup {
    font-size: 0.7rem;
    color: var(--muted-dim);
    margin-left: 0.2em;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 1.5rem 3rem;
    }
    .section {
      padding: 3rem 1rem;
    }
    #graph {
      padding: 0 1rem 3rem;
    }
  }
</style>
