---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ignamiranda">
  <main>
    <section class="hero">
      <h1>
        <span class="name">ignamiranda</span>
        <span class="tagline">builds things</span>
      </h1>
      <p class="blurb">
        A playground for software, design, and games.
      </p>
      <nav class="links">
        <a href="/name-generator">Name Generator</a>
        <a href="https://github.com/ignamiranda" target="_blank">GitHub</a>
        <a href="mailto:ignamiranda@users.noreply.github.com">Email</a>
      </nav>
    </section>
  </main>
</Layout>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  h1 {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .name {
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tagline {
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .blurb {
    font-size: 1.1rem;
    max-width: 32rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--fg);
    border: 1px solid var(--muted);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    transition: all 0.2s;
  }

  .links a:hover {
    border-color: var(--accent);
    color: var(--accent);
    opacity: 1;
  }
</style>
