---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { getBacklinks, getNoteDate } from "../../lib/backlinks";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const backlinks = getBacklinks(note.slug);
const date = getNoteDate(note.slug, note.data.date);
const tags = note.data.tags;
---

<Layout title={note.data.title}>
<main>
  <h1>{note.data.title || note.slug}</h1>

  {
    (date || (tags && tags.length > 0)) && (
      <p class="meta">
        {date && <time datetime={date}>{date}</time>}
        {date && tags && tags.length > 0 && <span class="sep">·</span>}
        {tags && tags.length > 0 && (
          <>
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag">{tag}</a>
            ))}
          </>
        )}
      </p>
    )
  }

  <Content />

  {
    backlinks.length > 0 && (
      <section class="backlinks">
        <h2>Linked from</h2>
        <ul>
          {backlinks.map((link) => (
            <li><a href={`/notes/${link.slug}`}>{link.title}</a></li>
          ))}
        </ul>
      </section>
    )
  }
</main>

<style>
  main {
    max-width: 42rem;
    margin: 4rem auto;
    padding: 0 1rem;
  }

  .backlinks {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--accent);
  }

  .backlinks h2 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .backlinks ul {
    list-style: none;
    padding: 0;
  }

  .backlinks li {
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0.5rem 0 2rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .sep {
    opacity: 0.4;
  }

  .tag {
    color: var(--accent);
    text-decoration: none;
  }

  .tag:hover {
    opacity: 0.7;
  }
</style>
</Layout>
