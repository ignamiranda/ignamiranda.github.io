<div class="generator" id="app">
  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <h2 class="sidebar-title">Drafts</h2>
      <button class="new-btn" id="new-btn">+ New generator</button>
      <ul class="draft-list" id="draft-list"></ul>
      <section class="favorites-tray" id="favorites-tray">
        <div class="favorites-header">
          <h3 class="favorites-title">Favorites</h3>
          <button type="button" class="favorites-clear" id="favorites-clear">Clear</button>
        </div>
        <ul class="favorites-list" id="favorites-list"></ul>
        <button type="button" class="favorites-copy" id="favorites-copy">Copy favorites</button>
      </section>
    </aside>

    <!-- Main -->
    <section class="main-area" id="main-area">
      <!-- Draft name -->
      <input type="text" class="draft-name" id="draft-name" placeholder="Name your generator..." />

      <!-- Example input -->
      <div class="input-section">
        <label class="section-label" for="example-input">Example names <span class="hint">— one per line</span></label>
        <textarea id="example-input" class="example-input" rows="8" placeholder="Paste one name per line..."></textarea>
        <div class="import-area" id="import-area">
          <span class="import-hint">Drop a .txt file here or <button type="button" class="link-btn" id="import-btn">click to upload</button></span>
          <input type="file" id="file-input" accept=".txt" hidden />
        </div>
      </div>

      <!-- Controls -->
      <div class="controls">
        <div class="control-row">
          <div class="count-control">
            <label for="count-select">Generate</label>
            <select id="count-select">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="25">25</option>
              <option value="50">50</option>
              <option value="100">100</option>
            </select>
            <span>names</span>
          </div>
          <button type="button" class="generate-btn" id="generate-btn">Generate</button>
        </div>

        <details class="advanced" id="advanced">
          <summary class="advanced-toggle">Advanced</summary>
          <div class="advanced-panel">
            <div class="advanced-row">
              <div class="field">
                <label for="min-length">Min length</label>
                <input type="number" id="min-length" value="4" min="2" max="30" />
              </div>
              <div class="field">
                <label for="max-length">Max length</label>
                <input type="number" id="max-length" value="12" min="2" max="30" />
              </div>
              <div class="field">
                <label for="seed">Seed</label>
                <input type="number" id="seed" min="0" placeholder="Random" />
              </div>
            </div>
          </div>
        </details>
      </div>

      <!-- Results -->
      <div class="results" id="results">
        <p class="placeholder">Click Generate to create names.</p>
      </div>
    </section>
  </div>
</div>

<script>
  import { MarkovChain } from "../lib/markov";
  import { loadDrafts, saveDrafts } from "../lib/generator-db";

  /* ─── DOM refs ─── */
  const $ = (id) => document.getElementById(id);
  /** @type {HTMLUListElement} */ const draftList = $("draft-list");
  /** @type {HTMLInputElement} */ const draftNameInput = $("draft-name");
  /** @type {HTMLTextAreaElement} */ const exampleInput = $("example-input");
  /** @type {HTMLInputElement} */ const fileInput = $("file-input");
  /** @type {HTMLButtonElement} */ const importBtn = $("import-btn");
  /** @type {HTMLDivElement} */ const importArea = $("import-area");
  /** @type {HTMLSelectElement} */ const countSelect = $("count-select");
  /** @type {HTMLButtonElement} */ const generateBtn = $("generate-btn");
  /** @type {HTMLDivElement} */ const resultsEl = $("results");
  /** @type {HTMLInputElement} */ const minLength = $("min-length");
  /** @type {HTMLInputElement} */ const maxLength = $("max-length");
  /** @type {HTMLInputElement} */ const seedInput = $("seed");
  /** @type {HTMLButtonElement} */ const newBtn = $("new-btn");
  /** @type {HTMLUListElement} */ const favoritesList = $("favorites-list");
  /** @type {HTMLButtonElement} */ const favoritesCopyBtn = $("favorites-copy");
  /** @type {HTMLButtonElement} */ const favoritesClearBtn = $("favorites-clear");

  /* ─── Helpers ─── */
  let saveTimer = null;
  function debouncedSave() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveState, 400);
  }

  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
  }

  function copyText(text) {
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).catch(() => {});
    }
  }

  function escapeHtml(text) {
    return text
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function normalizeDraft(draft) {
    return {
      ...draft,
      favorites: Array.isArray(draft.favorites) ? draft.favorites : [],
    };
  }

  function showError(message) {
    resultsEl.innerHTML = `<p class="placeholder" style="color: var(--accent);">${escapeHtml(message)}</p>`;
  }

  function confirmThen(message, btnLabel, onConfirm) {
    const overlay = document.createElement("div");
    overlay.className = "confirm-overlay";
    overlay.innerHTML = `
      <div class="confirm-box">
        <p>${escapeHtml(message)}</p>
        <div class="confirm-actions">
          <button class="btn btn-cancel">Cancel</button>
          <button class="btn btn-proceed">${escapeHtml(btnLabel)}</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);
    overlay.querySelector(".btn-cancel").addEventListener("click", () => overlay.remove());
    overlay.querySelector(".btn-proceed").addEventListener("click", () => {
      overlay.remove();
      onConfirm();
    });
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) overlay.remove();
    });
  }

  /* ─── State ─── */
  /** @type {import("../lib/generator-db").DraftsState | null} */
  let state = null;

  async function seedWithExamples() {
    const { exampleGenerators } = await import("../data/example-generators");
    const drafts = {};
    for (const eg of exampleGenerators) {
      const id = uid();
      drafts[id] = {
        id,
        name: eg.name,
        examples: eg.examples,
        settings: { count: 10, minLength: 4, maxLength: 12, seed: "" },
        favorites: [],
      };
    }
    const ids = Object.keys(drafts);
    state = { activeDraftId: ids[0], drafts };
  }

  (function init() {
    const loaded = loadDrafts();
    if (loaded && Object.keys(loaded.drafts).length > 0) {
      for (const id of Object.keys(loaded.drafts)) {
        loaded.drafts[id] = normalizeDraft(loaded.drafts[id]);
      }
      state = loaded;
    }
  })();

  /** @returns {import("../lib/generator-db").Draft | null} */
  function getActiveDraft() {
    return (state && state.drafts[state.activeDraftId]) || null;
  }

  function saveState() {
    const draft = getActiveDraft();
    if (draft) {
      draft.name = draftNameInput.value.trim().slice(0, 100) || "Untitled";
      const lines = exampleInput.value
        .split("\n")
        .map((s) => s.trim())
        .filter((s) => s.length > 0);
      if (lines.length > 5000) {
        showError(`Example list exceeds maximum of 5000 entries (${lines.length}).`);
        return;
      }
      for (const line of lines) {
        if (line.length > 200) {
          showError(`Example name exceeds 200 characters: "${line.slice(0, 40)}…".`);
          return;
        }
      }
      draft.examples = lines;
      const count = parseInt(countSelect.value, 10);
      draft.settings = {
        count: isNaN(count) ? 10 : count,
        minLength: parseInt(minLength.value, 10) || 4,
        maxLength: parseInt(maxLength.value, 10) || 12,
        seed: seedInput.value.trim() || "",
      };
    }
    saveDrafts(state);
  }

  /* ─── Render ─── */
  function render() {
    renderSidebar();
    renderActiveDraft();
    renderFavorites();
  }

  function renderSidebar() {
    draftList.innerHTML = "";
    const ids = Object.keys(state.drafts);
    for (const id of ids) {
      const draft = state.drafts[id];
      const li = document.createElement("li");
      li.className = "draft-item" + (id === state.activeDraftId ? " active" : "");
      li.textContent = draft.name || "Untitled";

      const del = document.createElement("button");
      del.className = "delete-btn";
      del.textContent = "\u00d7";
      del.title = "Delete draft";
      del.addEventListener("click", (e) => {
        e.stopPropagation();
        confirmThen("Are you sure you want to delete this generator?", "Delete", () => deleteDraft(id));
      });

      li.appendChild(del);
      li.addEventListener("click", () => selectDraft(id));
      draftList.appendChild(li);
    }
  }

  function renderActiveDraft() {
    const draft = getActiveDraft();
    if (!draft) {
      draftNameInput.value = "";
      exampleInput.value = "";
      resultsEl.innerHTML = '<p class="placeholder">Create a new generator to begin.</p>';
      return;
    }

    draftNameInput.value = draft.name || "";
    exampleInput.value = draft.examples.join("\n");
    countSelect.value = String(draft.settings.count || 10);
    minLength.value = String(draft.settings.minLength || 4);
    maxLength.value = String(draft.settings.maxLength || 12);
    seedInput.value = draft.settings.seed || "";

    resultsEl.innerHTML = '<p class="placeholder">Click Generate to create names.</p>';
  }

  function renderFavorites() {
    const draft = getActiveDraft();
    if (!draft) {
      favoritesList.innerHTML = "";
      favoritesCopyBtn.disabled = true;
      favoritesClearBtn.disabled = true;
      return;
    }

    const favorites = draft.favorites || [];
    if (favorites.length === 0) {
      favoritesList.innerHTML = '<li class="favorites-placeholder">No favorites yet.</li>';
      favoritesCopyBtn.disabled = true;
      favoritesClearBtn.disabled = true;
      return;
    }

    favoritesList.innerHTML = favorites
      .map(
        (name) =>
          `<li class="favorites-item"><span class="favorite-name">${escapeHtml(name)}</span><button type="button" class="favorite-remove" data-name="${escapeHtml(name)}" aria-label="Remove ${escapeHtml(name)}">\u00d7</button></li>`,
      )
      .join("");

    favoritesCopyBtn.disabled = false;
    favoritesClearBtn.disabled = false;

    favoritesList.querySelectorAll(".favorite-remove").forEach((el) => {
      el.addEventListener("click", () => {
        removeFavorite(el.dataset.name || "");
      });
    });
  }

  /* ─── Actions ─── */
  function selectDraft(id) {
    if (id === state.activeDraftId) return;
    saveState();
    state.activeDraftId = id;
    saveDrafts(state);
    render();
  }

  function deleteDraft(id) {
    delete state.drafts[id];
    const remaining = Object.keys(state.drafts);
    if (remaining.length === 0) {
      seedWithExamples().then(() => {
        saveDrafts(state);
        render();
      });
      return;
    }
    if (id === state.activeDraftId) {
      state.activeDraftId = remaining[0];
    }
    saveDrafts(state);
    render();
  }

  function createNew() {
    saveState();
    const raw = prompt("Name your generator:", "");
    if (!raw?.trim()) return;
    const name = raw.trim().slice(0, 100);
    const id = uid();
    state.drafts[id] = {
      id,
      name,
      examples: [],
      settings: { count: 10, minLength: 4, maxLength: 12, seed: "" },
      favorites: [],
    };
    state.activeDraftId = id;
    saveDrafts(state);
    render();
    draftNameInput.focus();
  }

  function generate() {
    saveState();
    const draft = getActiveDraft();
    if (!draft) return;

    const min = parseInt(minLength.value, 10);
    const max = parseInt(maxLength.value, 10);
    if (isNaN(min) || isNaN(max)) {
      showError("Min and max length must be valid numbers.");
      return;
    }
    if (min > max) {
      showError("Min length cannot be greater than max length.");
      return;
    }

    if (draft.examples.length < 3) {
      showError("Add at least 3 example names first.");
      return;
    }

    const seed = draft.settings.seed;
    let rng = Math.random;
    if (seed) {
      let s = seed ? parseInt(seed, 10) : NaN;
      if (isNaN(s)) s = hashString(seed);
      rng = () => {
        s = (s * 16807) % 2147483647;
        return (s - 1) / 2147483646;
      };
    }

    const chain = new MarkovChain(draft.examples, 2);
    chain.rng = rng;

    const names = chain.generateMany(draft.settings.count || 10, draft.settings.maxLength || 12);
    const requested = draft.settings.count || 10;

    if (names.length === 0) {
      showError("Could not generate names. Try adjusting your example list.");
      return;
    }

    let feedback = "";
    if (names.length < requested) {
      feedback = `<p class="placeholder" style="margin-bottom:0.5rem;">Generated ${names.length} names (requested ${requested}, not enough unique variants).</p>`;
    }

    const favoriteSet = new Set((draft.favorites || []).map((name) => name.toLowerCase()));

    resultsEl.innerHTML = feedback
      + names
        .map((name) => {
          const isFavorited = favoriteSet.has(name.toLowerCase());
          const starLabel = isFavorited ? "Unfavorite" : "Favorite";
          return `<span class="name-item" tabindex="0" data-name="${escapeHtml(name)}"><button type="button" class="favorite-toggle${isFavorited ? " active" : ""}" data-name="${escapeHtml(name)}" aria-label="${starLabel} ${escapeHtml(name)}">${isFavorited ? "\u2605" : "\u2606"}</button><span class="name-text">${escapeHtml(name)}</span></span>`;
        })
        .join("");

    resultsEl.querySelectorAll(".name-item").forEach((el) => {
      el.addEventListener("click", () => {
        copyText(el.dataset.name || "");
        el.classList.add("copied");
        setTimeout(() => el.classList.remove("copied"), 800);
      });
      el.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          el.click();
        }
      });
    });

    resultsEl.querySelectorAll(".favorite-toggle").forEach((el) => {
      el.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleFavorite(el.dataset.name || "");
      });
    });
  }

  function toggleFavorite(name) {
    const draft = getActiveDraft();
    if (!draft || !name) return;

    if (draft.favorites.length >= 500 && !draft.favorites.some((f) => f.toLowerCase() === name.toLowerCase())) {
      showError("Favorites limit reached (500). Remove some favorites first.");
      return;
    }

    const index = draft.favorites.findIndex((item) => item.toLowerCase() === name.toLowerCase());
    if (index >= 0) {
      draft.favorites.splice(index, 1);
    } else {
      draft.favorites.unshift(name);
    }

    saveDrafts(state);
    renderFavorites();
    updateResultFavoriteState();
  }

  function removeFavorite(name) {
    const draft = getActiveDraft();
    if (!draft || !name) return;
    draft.favorites = draft.favorites.filter((item) => item.toLowerCase() !== name.toLowerCase());
    saveDrafts(state);
    renderFavorites();
    updateResultFavoriteState();
  }

  function clearFavorites() {
    const draft = getActiveDraft();
    if (!draft) return;
    confirmThen("Are you sure you want to clear all favorites?", "Clear", () => {
      draft.favorites = [];
      saveDrafts(state);
      renderFavorites();
      updateResultFavoriteState();
    });
  }

  function updateResultFavoriteState() {
    const draft = getActiveDraft();
    if (!draft) return;
    const favoriteSet = new Set((draft.favorites || []).map((name) => name.toLowerCase()));
    resultsEl.querySelectorAll(".favorite-toggle").forEach((el) => {
      const name = el.dataset.name || "";
      const isFavorited = favoriteSet.has(name.toLowerCase());
      el.classList.toggle("active", isFavorited);
      el.textContent = isFavorited ? "\u2605" : "\u2606";
      el.setAttribute("aria-label", `${isFavorited ? "Unfavorite" : "Favorite"} ${name}`);
    });
  }

  function hashString(str) {
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
      const c = str.charCodeAt(i);
      hash = (hash << 5) - hash + c;
      hash |= 0;
    }
    return Math.abs(hash) || 1;
  }

  /* ─── File import ─── */
  function handleFile(file) {
    if (file.size > 1048576) {
      showError("File exceeds 1 MB limit. Please use a smaller file.");
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target.result;
      const lines = text.split("\n").map((s) => s.trim()).filter((s) => s.length > 0);
      if (lines.length === 0) return;

      if (lines.length > 5000) {
        showError(`Imported file has ${lines.length} entries (max 5000).`);
        return;
      }
      for (const line of lines) {
        if (line.length > 200) {
          showError(`Imported name exceeds 200 characters: "${line.slice(0, 40)}…".`);
          return;
        }
      }

      const choice = confirm("Replace current list with imported names?\n\n\u2022 OK = Replace\n\u2022 Cancel = Append");
      const draft = getActiveDraft();
      if (!draft) return;

      if (choice) {
        draft.examples = lines;
      } else {
        const existing = new Set(draft.examples.map((s) => s.toLowerCase()));
        for (const line of lines) {
          if (!existing.has(line.toLowerCase())) {
            draft.examples.push(line);
            existing.add(line.toLowerCase());
          }
        }
      }
      saveState();
      renderActiveDraft();
    };
    reader.onerror = () => {
      showError("Failed to read file. Please try again.");
    };
    reader.readAsText(file);
  }

  importBtn.addEventListener("click", () => fileInput.click());
  fileInput.addEventListener("change", () => {
    if (fileInput.files[0]) handleFile(fileInput.files[0]);
    fileInput.value = "";
  });

  importArea.addEventListener("dragover", (e) => {
    e.preventDefault();
    importArea.classList.add("drag-over");
  });
  importArea.addEventListener("dragleave", () => {
    importArea.classList.remove("drag-over");
  });
  importArea.addEventListener("drop", (e) => {
    e.preventDefault();
    importArea.classList.remove("drag-over");
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });

  /* ─── Auto-save on input ─── */
  draftNameInput.addEventListener("input", debouncedSave);
  exampleInput.addEventListener("input", debouncedSave);
  countSelect.addEventListener("change", debouncedSave);
  minLength.addEventListener("input", debouncedSave);
  maxLength.addEventListener("input", debouncedSave);
  seedInput.addEventListener("input", debouncedSave);

  /* ─── Button handlers ─── */
  generateBtn.addEventListener("click", generate);
  newBtn.addEventListener("click", createNew);
  favoritesCopyBtn.addEventListener("click", () => {
    const draft = getActiveDraft();
    if (!draft || draft.favorites.length === 0) return;
    copyText(draft.favorites.join("\n"));
    favoritesCopyBtn.textContent = "Copied";
    setTimeout(() => {
      favoritesCopyBtn.textContent = "Copy favorites";
    }, 800);
  });
  favoritesClearBtn.addEventListener("click", clearFavorites);

  /* ─── Init ─── */
  if (state === null) {
    seedWithExamples().then(() => {
      saveDrafts(state);
      render();
    });
  } else {
    render();
  }
</script>

<style>
  .generator {
    min-height: 60vh;
    padding: 2rem 0;
  }

  .layout {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
  }

  /* ─── Sidebar ─── */
  .sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
  }

  .sidebar-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }

  .new-btn {
    all: unset;
    display: block;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    cursor: pointer;
    padding: 0.5rem 0.75rem;
    border: 1px dashed var(--accent);
    border-radius: 6px;
    text-align: center;
    margin-bottom: 0.75rem;
    transition: all 0.2s;
  }
  .new-btn:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .draft-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .favorites-tray {
    margin-top: 1rem;
    padding-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--fg) 10%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .favorites-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .favorites-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .favorites-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    max-height: 14rem;
    overflow-y: auto;
    padding-right: 0.2rem;
  }

  .favorites-placeholder {
    font-size: 0.82rem;
    color: var(--muted);
    font-style: italic;
  }

  .favorites-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.84rem;
    padding: 0.35rem 0.45rem;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--fg) 12%, transparent);
    background: color-mix(in srgb, var(--fg) 4%, transparent);
  }

  .favorite-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .favorites-clear,
  .favorites-copy,
  .favorite-remove {
    all: unset;
    cursor: pointer;
    font-family: var(--font-mono);
    color: var(--muted);
  }

  .favorites-copy {
    border: 1px solid color-mix(in srgb, var(--fg) 15%, transparent);
    border-radius: 6px;
    text-align: center;
    padding: 0.4rem 0.5rem;
    font-size: 0.78rem;
    transition: all 0.15s;
  }
  .favorites-clear {
    font-size: 0.75rem;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .favorites-clear:hover,
  .favorites-copy:hover,
  .favorite-remove:hover {
    color: var(--accent);
  }
  .favorites-copy:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .favorites-copy:disabled,
  .favorites-clear:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .favorite-remove {
    font-size: 0.95rem;
    line-height: 1;
    padding: 0 0.2rem;
  }

  .draft-item {
    font-size: 0.9rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    transition: all 0.15s;
    color: var(--fg);
  }
  .draft-item:hover {
    background: color-mix(in srgb, var(--fg) 6%, transparent);
  }
  .draft-item.active {
