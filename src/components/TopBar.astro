---
import { getAllNotes } from "../lib/backlinks";

const notes = getAllNotes();
---

<header class="top-bar">
  <div class="top-bar-inner">
    <a href="/" class="top-bar-logo">ignamiranda</a>
    <nav class="top-bar-nav">
      <a href="#" class="top-bar-link" id="random-link">Random</a>
      <div class="search-wrapper">
        <input
          type="search"
          class="top-bar-search"
          placeholder="Search notes..."
          aria-label="Search notes"
        />
        <div class="search-dropdown" id="search-dropdown" aria-live="polite"></div>
      </div>
    </nav>
  </div>
</header>

<script type="application/json" id="topbar-notes-data">
  {JSON.stringify(notes)}
</script>

<script>
(() => {
  // -- Random link --
  const link = document.getElementById("random-link");
  const dataEl = document.getElementById("topbar-notes-data");
  if (link && dataEl) {
    const notes = JSON.parse(dataEl.textContent || "[]");
    link.addEventListener("click", (e) => {
      e.preventDefault();
      if (!notes.length) return;
      const pick = notes[Math.floor(Math.random() * notes.length)];
      window.location.href = "/notes/" + encodeURIComponent(pick.slug);
    });
  }

  // -- Search --
  const searchInput = document.querySelector(".top-bar-search");
  const searchDropdown = document.getElementById("search-dropdown");

  if (searchInput && searchDropdown) {
    let miniSearch = null;
    let fetched = false;
    let selectedIndex = -1;

    async function ensureIndex() {
      if (fetched) return;
      fetched = true;
      let success = false;
      try {
        const [MiniSearch, res] = await Promise.all([
          import("minisearch").then(m => m.default || m),
          fetch("/search-index.json"),
        ]);
        const docs = await res.json();
        if (!docs.length) return;
        const ms = new MiniSearch({
          fields: ["title", "preview", "tags"],
          storeFields: ["slug", "title", "preview"],
        });
        ms.addAll(docs);
        miniSearch = ms;
        success = true;
      } catch {
        // index unavailable
      }
      if (!success) fetched = false;
    }

    function escapeHtml(str) {
      const d = document.createElement("div");
      d.textContent = str;
      return d.innerHTML;
    }

    function renderResults(query) {
      if (!miniSearch || !query.trim()) {
        searchDropdown.innerHTML = "";
        searchDropdown.classList.remove("visible");
        selectedIndex = -1;
        return;
      }
      const results = miniSearch.search(query, { prefix: true, fuzzy: 0.2 });
      if (!results.length) {
        searchDropdown.innerHTML = '<div class="search-no-results">No notes found for "' + escapeHtml(query) + '"</div>';
        searchDropdown.classList.add("visible");
        selectedIndex = -1;
        return;
      }
      selectedIndex = -1;
      searchDropdown.innerHTML = results
        .map(
          (r, i) =>
            `<div class="search-result-item" data-index="${i}" data-slug="${escapeHtml(r.slug)}" role="option">
              <div class="search-result-title">${escapeHtml(r.title)}</div>
              <div class="search-result-preview">${escapeHtml(r.preview)}</div>
            </div>`,
        )
        .join("");
      searchDropdown.classList.add("visible");
    }

    function navigateTo(slug) {
      window.location.href = "/notes/" + encodeURIComponent(slug);
    }

    function getSelectedSlug() {
      const sel = searchDropdown.querySelector(".search-result-item.selected");
      return sel ? sel.dataset.slug : null;
    }

    function selectNext() {
      const items = searchDropdown.querySelectorAll(".search-result-item");
      if (!items.length) return;
      if (selectedIndex >= 0) items[selectedIndex].classList.remove("selected");
      selectedIndex = (selectedIndex + 1) % items.length;
      items[selectedIndex].classList.add("selected");
      items[selectedIndex].scrollIntoView({ block: "nearest" });
    }

    function selectPrev() {
      const items = searchDropdown.querySelectorAll(".search-result-item");
      if (!items.length) return;
      if (selectedIndex >= 0) items[selectedIndex].classList.remove("selected");
      selectedIndex = (selectedIndex - 1 + items.length) % items.length;
      items[selectedIndex].classList.add("selected");
      items[selectedIndex].scrollIntoView({ block: "nearest" });
    }

    function closeDropdown() {
      searchDropdown.innerHTML = "";
      searchDropdown.classList.remove("visible");
      selectedIndex = -1;
      searchInput.blur();
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && !e.ctrlKey && !e.metaKey && !e.repeat) {
        const tag = e.target.tagName;
        if (tag !== "INPUT" && tag !== "TEXTAREA" && !e.target.isContentEditable) {
          e.preventDefault();
          searchInput.focus();
        }
      }
    });

    searchInput.addEventListener("focus", () => {
      ensureIndex();
    });

    searchInput.addEventListener("input", () => {
      renderResults(searchInput.value);
    });

    searchInput.addEventListener("keydown", (e) => {
      if (!searchDropdown.classList.contains("visible")) return;
      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          selectNext();
          break;
        case "ArrowUp":
          e.preventDefault();
          selectPrev();
          break;
        case "Enter":
          e.preventDefault();
          const slug = getSelectedSlug();
          if (slug) navigateTo(slug);
          break;
        case "Escape":
          e.preventDefault();
          closeDropdown();
          break;
      }
    });

    searchDropdown.addEventListener("click", (e) => {
      const item = e.target.closest(".search-result-item");
      if (item) navigateTo(item.dataset.slug);
    });

    document.addEventListener("click", (e) => {
      if (!e.target.closest(".search-wrapper")) {
        searchDropdown.classList.remove("visible");
        selectedIndex = -1;
      }
    });
  }
})();
</script>
