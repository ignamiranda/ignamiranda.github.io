<div class="rumor-generator" id="rumor-generator">
  <output class="rumor-output" id="rumor-output">
    <p class="rumor-text" id="rumor-text">Press Generate for a tavern rumor.</p>
  </output>
  <div class="rumor-controls">
    <button type="button" class="rumor-btn" id="rumor-btn">Generate rumor</button>
    <button type="button" class="copy-btn" id="copy-btn" title="Copy rumor">Copy</button>
  </div>
</div>

<script>
  import tracery from "tracery-grammar";
  import { rumorGrammar } from "../data/rumors-grammar";

  const btn = document.getElementById("rumor-btn")!;
  const copyBtn = document.getElementById("copy-btn")!;
  const output = document.getElementById("rumor-text")!;
  let currentRumor = "";

  const grammar = tracery.createGrammar(rumorGrammar);
  grammar.addModifiers(tracery.baseEngModifiers);

  function generate() {
    currentRumor = grammar.flatten("#origin#");
    output.textContent = currentRumor;
    copyBtn.textContent = "Copy";
  }

  btn.addEventListener("click", generate);

  copyBtn.addEventListener("click", async () => {
    if (!currentRumor) return;
    try {
      await navigator.clipboard.writeText(currentRumor);
      copyBtn.textContent = "Copied!";
      setTimeout(() => { copyBtn.textContent = "Copy"; }, 1500);
    } catch {
      copyBtn.textContent = "Failed";
    }
  });

  generate();
</script>

<style>
  .rumor-generator {
    max-width: 42rem;
    margin: 0 auto;
  }

  .rumor-output {
    display: block;
    background: color-mix(in srgb, var(--fg) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--fg) 10%, transparent);
    border-radius: 0.5rem;
    padding: 1.75rem 2rem;
    min-height: 6rem;
    margin-bottom: 1.25rem;
  }

  .rumor-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--fg);
    margin: 0;
    font-style: italic;
    transition: opacity 0.2s;
  }

  .rumor-controls {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .rumor-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.6rem 1.25rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 0.35rem;
    cursor: pointer;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .rumor-btn:hover {
    opacity: 0.85;
  }

  .copy-btn {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.6rem 1rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid color-mix(in srgb, var(--fg) 15%, transparent);
    border-radius: 0.35rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .copy-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .rumor-output {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
